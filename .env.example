# Copie este arquivo para .env e preencha os valores reais
# NUNCA suba o arquivo .env para controle de versão

# OBRIGATÓRIO em produção — gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque_para_uma_chave_secreta_longa_e_aleatoria

# Senha do admin padrão (usada apenas na primeira inicialização)
ADMIN_PASSWORD=TroqueEsteValorImediatamente!

# URL do banco de dados (padrão: SQLite local)
# Para PostgreSQL: postgresql://usuario:senha@host:5432/lego_db
DATABASE_URL=sqlite:///lego_pro.db

# Modo debug (nunca true em produção)
FLASK_DEBUG=false
